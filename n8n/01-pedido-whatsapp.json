        "jsCode": "const row = $input.first().json;\nconst ctx = row.items_json;\nconst items_validos = ctx.items_validos || [];\nconst items_no_disponibles = ctx.items_no_disponibles || [];\n\nconst avisos = items_no_disponibles\n  .map(i => `De *${i.nombre}* solo me quedan ${i.disponible} ${i.disponible === 1 ? 'unidad' : 'unidades'} (pediste ${i.cantidad_pedida}). Si te sirven, dime \"dame los ${i.disponible} de ${i.nombre}\", o cambia el producto.`)\n  .join('\\n\\n');\n\nconst confirmados = items_validos.length\n  ? `Hasta ahora tengo confirmado: ${items_validos.map(i => `${i.cantidad} x ${i.nombre}`).join(', ')}.\\n\\n`\n  : '';\n\nreturn [{\n  json: {\n    numero_whatsapp: row.numero_whatsapp,\n    texto_respuesta: `${confirmados}${avisos}`\n  }\n}];"
      },
