    {
      "parameters": {
        "jsCode": "const previo = $('Preparar contexto IA').first().json;\nconst raw = $input.first().json;\n\nlet content =\n  raw.output?.[0]?.content?.[0]?.text ??\n  raw.choices?.[0]?.message?.content ??\n  raw.message?.content ??\n  raw.content ??\n  raw.text ??\n  (typeof raw === 'string' ? raw : JSON.stringify(raw));\n\ncontent = String(content)\n  .trim()\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/, '')\n  .replace(/```\\s*$/, '')\n  .trim();\n\nlet parsed;\nlet parseError = null;\ntry {\n  parsed = JSON.parse(content);\n} catch (e) {\n  parsed = { intencion: 'otro', productos: [] };\n  parseError = e.message;\n}\n\nreturn [{\n  json: {\n    numero_whatsapp: previo.numero_whatsapp,\n    nombre: previo.nombre,\n    texto: previo.texto,\n    intencion: parsed.intencion || 'otro',\n    productos: parsed.productos || [],\n    respuesta: parsed.respuesta || 'Cuentame en que te puedo ayudar: puedes pedir productos, preguntar por tu pedido, o escribir \"menu\" para ver las opciones 😊',\n    contexto_items_validos_previos: previo.contexto_items_validos_previos || [],\n    _debug_texto_original: previo.texto,\n    _debug_respuesta_ia: content,\n    _debug_parse_error: parseError\n  }\n}];"
      },
