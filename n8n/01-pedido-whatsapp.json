      "parameters": {
        "jsCode": "const body = $input.first().json;\nconst value = body.entry?.[0]?.changes?.[0]?.value;\nconst message = body.messages?.[0] || value?.messages?.[0];\n\nif (!message) {\n  // Es un callback de estado (entregado/leido), no un mensaje nuevo. Se ignora.\n  return [];\n}\n\nconst contact = body.contacts?.[0] || value?.contacts?.[0];\n\nreturn [{\n  json: {\n    numero_whatsapp: message.from,\n    nombre: contact?.profile?.name || message.from,\n    tipo: message.type,\n    texto: message.text?.body || '',\n    boton_id: message.interactive?.button_reply?.id || message.interactive?.list_reply?.id || null\n  }\n}];"
      },
