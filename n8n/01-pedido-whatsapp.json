      "parameters": {
        "jsCode": "const items = $input.all().map(i => i.json);\nconst productos = Array.isArray(items[0]) ? items[0] : items;\n\nconst porCategoria = {};\nfor (const p of productos) {\n  const cat = p.categoria?.nombre || 'Otros';\n  if (!porCategoria[cat]) porCategoria[cat] = [];\n  porCategoria[cat].push(`- ${p.nombre}: $${p.precio} (${p.unidad_medida})`);\n}\n\nconst secciones = Object.entries(porCategoria)\n  .map(([cat, lineas]) => `*${cat}*\\n${lineas.join('\\n')}`)\n  .join('\\n\\n');\n\nconst previo = $('Normalizar evento entrante').first().json;\n\nreturn [{\n  json: {\n    numero_whatsapp: previo.numero_whatsapp,\n    texto_catalogo: `Nuestro catalogo:\\n\\n${secciones}`\n  }\n}];"
      },
