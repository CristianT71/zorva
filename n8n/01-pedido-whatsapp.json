      "parameters": {
        "jsCode": "const previo = $input.first().json;\nconst backendUrl = 'https://zorva-production.up.railway.app/api';\nconst productos = previo.productos || [];\n\nconst items_validos = [...(previo.contexto_items_validos_previos || [])];\nconst items_no_disponibles = [];\n\nfor (const p of productos) {\n  const resultado = await this.helpers.httpRequest({\n    method: 'GET',\n    url: `${backendUrl}/productos`,\n    qs: { search: p.nombre },\n    json: true\n  });\n  const match = resultado[0];\n\n  if (!match || match.stock_actual < p.cantidad) {\n    items_no_disponibles.push({\n      nombre: p.nombre,\n      cantidad_pedida: p.cantidad,\n      disponible: match ? match.stock_actual : 0\n    });\n  } else {\n    const item = {\n      producto_id: match.id,\n      nombre: match.nombre,\n      cantidad: p.cantidad,\n      precio_unitario: match.precio,\n      subtotal: match.precio * p.cantidad\n    };\n    const idx = items_validos.findIndex(i => i.producto_id === match.id);\n    if (idx >= 0) items_validos[idx] = item; else items_validos.push(item);\n  }\n}\n\nreturn [{\n  json: {\n    numero_whatsapp: previo.numero_whatsapp,\n    nombre: previo.nombre,\n    items_validos,\n    items_no_disponibles,\n    todo_disponible: items_no_disponibles.length === 0 && items_validos.length > 0\n  }\n}];"
      },
