    {
      "parameters": {
        "jsCode": "const previo = $('Normalizar evento entrante').first().json;\nconst fila = $input.first().json;\nconst ctx = fila && fila.items_json ? fila.items_json : null;\n\nlet contexto_texto = '';\nconst validos_previos = ctx?.items_validos || [];\nconst faltantes_previos = ctx?.items_no_disponibles || [];\n\nif (validos_previos.length || faltantes_previos.length) {\n  const partes = [];\n  if (validos_previos.length) {\n    partes.push('Productos que el cliente ya confirmo en este pedido: ' + validos_previos.map(i => `${i.cantidad} x ${i.nombre}`).join(', '));\n  }\n  if (faltantes_previos.length) {\n    partes.push('Productos que el cliente pidio pero NO habia stock suficiente (le ofrecimos la cantidad disponible): ' + faltantes_previos.map(i => `${i.nombre} (pidio ${i.cantidad_pedida}, solo hay ${i.disponible})`).join(', '));\n  }\n  contexto_texto = 'CONTEXTO_PREVIO_DE_LA_CONVERSACION: ' + partes.join('. ') + '. Si el mensaje del cliente es una respuesta corta o ambigua relacionada con esto (ej. \"dame los que hay\", \"esos 8\", \"si, esos\", \"dale con eso\"), usa este contexto para deducir el producto y la cantidad exactos en vez de dejar productos vacio.';\n}\n\nreturn [{\n  json: {\n    ...previo,\n    contexto_texto,\n    contexto_items_validos_previos: validos_previos\n  }\n}];"
      },
      "id": "d3f1a2b4-6e7c-4a1e-9f3d-1a2b3c4d5e06",
